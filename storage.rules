rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Driveway letter exhibit photos
    // Uploaded by any authenticated user; readable by any authenticated user
    match /driveway-letters/{planId}/{filename} {
      allow read:   if request.auth != null;
      allow write:  if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Council district presentation slides
    // Uploadable by SFTC, MOT, Admin, CR — all authenticated roles
    match /cd-slides/{planId}/{filename} {
      allow read:   if request.auth != null;
      allow write:  if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Library template/sample files (e.g. sample CD slide templates)
    match /library/{filename} {
      allow read:   if request.auth != null;
      allow write:  if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Catch-all: any other paths require authentication
    match /{allPaths=**} {
      allow read:   if request.auth != null;
      allow write:  if request.auth != null;
      allow delete: if request.auth != null;
    }

  }
}
